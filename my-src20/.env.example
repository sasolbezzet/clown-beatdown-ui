# Seismic Testnet environment variables
# --------------------------------------------------
# RPC endpoint for the Seismic Testnet (replace if you run a local node)
RPC_URL=https://gcp-1.seismictest.net/rpc

# Private key of the account that will deploy and interact with the contracts.
# Keep this secret! Never commit a real key to the repository.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
